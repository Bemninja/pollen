---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import "../styles/tobii.min.css";
---

<MainLayout title="Pollen of the Sakura">
  <section class="hidden md:block h-screen overflow-y-scroll snap-y snap-mandatory
         scroll-smooth overscroll-contain
         scroll-behavior-smooth
         scroll-padding-top-12
         px-10 md:px-40 lg:px-80 xl:px-[10rem] bg-black">
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/1.png" alt="pollen 1" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/2.png" alt="pollen 2" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/3.png" alt="pollen 3" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/4.png" alt="pollen 4" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/5.png" alt="pollen 5" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/6.png" alt="pollen 6" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/7.png" alt="pollen 7" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/8.png" alt="pollen 8" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/9.png" alt="pollen 9" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/10.png" alt="pollen 10" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/11.png" alt="pollen 11" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/12.png" alt="pollen 13" />
    </div>
    <div class="snap-start min-h-screen flex justify-center py-20">
      <img src="../assets/images/13.png" alt="pollen 13" />
    </div>
  </section>
</MainLayout>
